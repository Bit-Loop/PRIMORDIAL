{
  "name": "credentialed-access-check",
  "version": "0.1.0",
  "description": "Verify operator-provided known credentials over evidence-supported Windows SMB/WinRM and collect lab flags only when active Operator Intent explicitly allows it.",
  "capability_tags": ["credentialed-access-check", "credential-use", "smb-session", "winrm", "flag-collection", "finding-verification"],
  "allowed_phases": ["exploitation"],
  "runtime": "host",
  "risk_tier": "high",
  "side_effect_level": "read_only",
  "required_secrets": ["lab.username", "lab.password"],
  "input_schema": {"target_id": "string", "credentialed_access_surface": "object", "protocols": "array<string>"},
  "output_schema": {
    "auth_results": "array<object>",
    "flag_hits": "array<object>",
    "command_results": "array<object>"
  },
  "timeout_seconds": 120,
  "retry_policy": {"max_attempts": 1},
  "evidence_adapter": "credentialed_access_results",
  "sandbox_profile": "restricted-network-readonly",
  "healthcheck": "smbclient/netexec available for evidence-gated Windows SMB/WinRM verification",
  "metadata": {"bundles": ["auth-session", "windows-credential-validation"], "profile_support": ["credential_validation", "htb_lab"], "mutates_target": false}
}
