{
  "name": "credentialed-access-check",
  "version": "0.1.0",
  "description": "Verify operator-provided lab credentials over SMB/WinRM and collect user/root flags only after valid authentication.",
  "capability_tags": ["credentialed-access-check", "credential-use", "smb-session", "winrm", "flag-collection", "finding-verification"],
  "allowed_phases": ["exploitation"],
  "runtime": "host",
  "risk_tier": "high",
  "side_effect_level": "read_only",
  "required_secrets": ["lab.username", "lab.password"],
  "input_schema": {"target_id": "string"},
  "output_schema": {
    "auth_results": "array<object>",
    "flag_hits": "array<object>",
    "command_results": "array<object>"
  },
  "timeout_seconds": 120,
  "retry_policy": {"max_attempts": 1},
  "evidence_adapter": "credentialed_access_results",
  "sandbox_profile": "restricted-network-readonly",
  "healthcheck": "netexec/evil-winrm available for credentialed HTB verification",
  "metadata": {"bundles": ["auth-session", "htb-specific"], "profile_support": ["hack_the_box"], "mutates_target": false}
}
