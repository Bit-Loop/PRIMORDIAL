{
  "service_id": "agent_chat_api",
  "description": "Standalone HTTP API that wraps local Codex and Claude Code chat CLIs.",
  "runtime_boundary": "Intentionally separate from PRIMORDIAL runtime code; runtime modules use the Python standard library and launch providers with exact subprocess argv lists.",
  "default_provider": "codex",
  "fallback_providers": [
    "codex",
    "claude"
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/health"
    },
    {
      "method": "GET",
      "path": "/api/health"
    },
    {
      "method": "GET",
      "path": "/providers"
    },
    {
      "method": "GET",
      "path": "/api/providers"
    },
    {
      "method": "POST",
      "path": "/api/chat"
    },
    {
      "method": "POST",
      "path": "/v1/chat/completions"
    }
  ],
  "provider_defaults": {
    "shell_allowed": false,
    "codex": {
      "command": [
        "codex",
        "exec"
      ],
      "sandbox": "read-only",
      "ephemeral": true,
      "dangerous_sandboxes_env": "CHAT_API_ALLOW_DANGEROUS_SANDBOXES"
    },
    "claude": {
      "command": [
        "claude",
        "-p"
      ],
      "json_output": true,
      "tools": "",
      "permission_mode": "dontAsk"
    }
  },
  "run_command": [
    "python3",
    "app.py",
    "--host",
    "127.0.0.1",
    "--port",
    "8787",
    "--workspace-root",
    "$PWD"
  ],
  "health_check": {
    "method": "GET",
    "url": "http://127.0.0.1:8787/health"
  },
  "model_prefixes": [
    "claude:sonnet",
    "claude:opus",
    "codex:gpt-5.5"
  ],
  "request_controls": {
    "workspace_root_env": "CHAT_API_WORKSPACE_ROOT",
    "auth_env": "CHAT_API_KEY",
    "request_id_required": true,
    "include_raw_redacts_session_and_token_fields": true,
    "safe_guard_default": true,
    "persistent_conversations_opt_in_field": "conversation_id"
  },
  "request_fields": [
    "provider",
    "prompt",
    "messages",
    "model",
    "cwd",
    "timeout_seconds",
    "dry_run",
    "stream",
    "fallback",
    "include_raw",
    "safe_guard",
    "conversation_id",
    "persist",
    "allow_tools",
    "claude_tools",
    "claude_permission_mode",
    "codex_sandbox",
    "codex_ephemeral"
  ],
  "streaming_events": [
    "meta",
    "provider_event",
    "delta",
    "done",
    "error"
  ],
  "environment": {
    "CHAT_API_KEY": "optional bearer auth",
    "CHAT_API_DEFAULT_PROVIDER": "default provider name",
    "CHAT_API_FALLBACK_PROVIDERS": "ordered fallback provider list",
    "CHAT_API_PROVIDER_FALLBACK_ENABLED": "enable automatic fallback",
    "CHAT_API_AUDIT_LOG": "redacted provider fallback audit JSONL path",
    "CHAT_API_TIMEOUT_SECONDS": "default provider timeout",
    "CHAT_API_MAX_PROMPT_CHARS": "maximum accepted prompt length",
    "CHAT_API_WORKSPACE_ROOT": "root that constrains request cwd values",
    "CHAT_API_RATE_LIMIT_ENABLED": "enable fixed-window live request limits",
    "CHAT_API_RATE_LIMIT_WINDOW_SECONDS": "rate limit window",
    "CHAT_API_RATE_LIMIT_REQUESTS": "requests per window"
  },
  "rate_limits": {
    "live_requests_only": true,
    "dry_run_health_and_providers_exempt": true,
    "default_window_seconds": 60,
    "default_requests": 30
  },
  "generated_markdown": {
    "path": "runtime/test-results",
    "pattern": "test-results-*.md",
    "latest": "latest.md",
    "ingest_allowed": false,
    "operational_retrieval_allowed": false
  },
  "test_runner": {
    "command": [
      "python3",
      "-B",
      "run_test_suite.py"
    ],
    "discovers": "tests/test*.py",
    "live_models": false
  },
  "service_asset": {
    "systemd_user_unit": "systemd/agent-chat-api.service",
    "environment_override": "runtime/agent-chat-api.env"
  },
  "user_service_install_targets": [
    "~/.config/systemd/user/agent-chat-api.service",
    "systemctl --user daemon-reload",
    "systemctl --user enable --now agent-chat-api.service",
    "systemctl --user status agent-chat-api.service"
  ],
  "provider_reference_sources": [
    "OpenAI Codex non-interactive mode docs: codex exec, JSON events, --output-last-message.",
    "OpenAI Codex GitHub README: local Codex CLI installation and CLI role.",
    "Claude Code CLI docs: claude -p, JSON output, --tools, permission mode flags.",
    "Anthropic claude-agent-sdk-python README: async query shape and separate concerns for tool permissions and tool availability."
  ]
}
